# ============================================================
# Aether Frontend Environment Variables
# 
# IMPORTANT: 
# - Copy this file to .env.local
# - Fill in all required values before running dev server
# - NEXT_PUBLIC_* vars are exposed to the browser (don't add secrets)
# - Never commit .env.local to version control
# ============================================================

# ==================== API & WebSocket ====================
# Backend API endpoint (dev: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket endpoint for real-time features (dev: ws://localhost:3001)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ==================== Blockchain: Base Sepolia ====================
# Chain ID for Base Sepolia testnet
NEXT_PUBLIC_CHAIN_ID=84532

# RPC endpoint for Base Sepolia
# Production RPC: https://sepolia.base.org
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# ==================== Web3: WalletConnect ====================
# Get FREE Project ID from https://cloud.walletconnect.com
# 1. Sign up for free
# 2. Create a new project
# 3. Copy Project ID from dashboard
# REQUIRED for RainbowKit wallet connections
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# ==================== Storage: IPFS (Pinata) ====================
# Pinata gateway URL for reading IPFS content
# Free public gateway: https://gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Optional: Pinata API key for uploads
# Get FREE API key from https://app.pinata.cloud
# Only needed if uploading files (chat attachments, profile pics, etc)
NEXT_PUBLIC_PINATA_API_KEY=your_api_key_here

# ==================== App Settings ====================
# Node environment (development | production)
NODE_ENV=development

# Enable debug logging for wallet connection
NEXT_PUBLIC_DEBUG=false

# ==================== Optional: AI Service ====================
# Local Ollama service URL (for optional AI features)
# Default: http://localhost:11434 (if running locally)
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:11434
