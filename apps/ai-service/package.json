{
  "name": "@aether/ai-service",
  "version": "0.1.0",
  "description": "Aether AI service - FastAPI + Ollama",
  "private": true,
  "scripts": {
    "dev": "cd src && python -m uvicorn main:app --reload --host 0.0.0.0 --port 5000",
    "build": "echo 'No build step for Python FastAPI'",
    "start": "cd src && python -m uvicorn main:app --host 0.0.0.0 --port 5000",
    "lint": "cd src && ruff check .",
    "lint:fix": "cd src && ruff check . --fix",
    "type-check": "cd src && mypy .",
    "test": "cd src && pytest"
  }
}
