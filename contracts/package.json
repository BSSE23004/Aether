{
  "name": "aether-contracts",
  "version": "0.1.0",
  "description": "Aether smart contracts - Foundry + Solidity",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "test:coverage": "forge coverage",
    "test:gas": "forge test --gas-report",
    "test:ci": "forge test --ci",
    "deploy:base-sepolia": "forge script script/DeployAll.s.sol:DeployAll --rpc-url $BASE_SEPOLIA_RPC_URL --private-key $PRIVATE_KEY --broadcast --verify",
    "deploy:registry": "forge script script/DeployCommunityRegistry.s.sol:DeployCommunityRegistry --rpc-url $BASE_SEPOLIA_RPC_URL --private-key $PRIVATE_KEY --broadcast --verify",
    "deploy:local": "forge script script/DeployAll.s.sol:DeployAll --rpc-url $LOCALHOST_RPC_URL --private-key $PRIVATE_KEY --broadcast",
    "verify": "forge verify-contract",
    "clean": "forge clean",
    "format": "forge fmt",
    "format:check": "forge fmt --check",
    "slither": "slither . --hardhat-ignore-compile"
  }
}
