# Aether Root Environment Configuration
# Copy this file to .env.local and configure for your environment

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development

# ============================================================================
# API SERVER
# ============================================================================
API_PORT=3001
API_URL=http://localhost:3001

# ============================================================================
# FRONTEND
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://aether:aether123@localhost:5432/aether_dev
POSTGRES_USER=aether
POSTGRES_PASSWORD=aether123
POSTGRES_DB=aether_dev

# ============================================================================
# CACHE & PUBSUB (Redis)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# BLOCKCHAIN (Base Sepolia)
# ============================================================================
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
PRIVATE_KEY=

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRY=24h

# ============================================================================
# STORAGE & PINNING (IPFS via Pinata - Optional)
# ============================================================================
PINATA_API_KEY=
PINATA_API_SECRET=

# ============================================================================
# AI SERVICE (Ollama - Optional, Local Only)
# ============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
AI_SERVICE_PORT=5000

# ============================================================================
# INDEXER SERVICE
# ============================================================================
INDEXER_BATCH_SIZE=100
INDEXER_POLL_INTERVAL=5000

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=debug
